# Copy this file to .env and fill in values before running docker compose up

# Required: random string used to sign JWTs — keep secret
JWT_SECRET=change-me-to-a-long-random-string

# Required: Groq API key for chatbot
GROQ_API_KEY=your-groq-key-here

# Optional: override default Groq model
GROQ_MODEL=llama-3.1-8b-instant

# Optional: GitHub token for higher rate limits on README fetching
GITHUB_TOKEN=

# Paths inside the container — no need to change these
DB_PATH=/data/tracker.db
UPLOAD_DIR=/data/uploads
WEB_DIST=/app/web/dist
