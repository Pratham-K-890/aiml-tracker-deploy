# Optional — copy to .env to override defaults.
# The app runs without this file; defaults are set in docker-compose.yml.

# Strongly recommended for production: replace with a long random string
JWT_SECRET=change-me-to-a-long-random-string

# Groq API key — required only for the AI chatbot feature
GROQ_API_KEY=your-groq-key-here

# Optional overrides
GROQ_MODEL=llama-3.1-8b-instant
GITHUB_TOKEN=
