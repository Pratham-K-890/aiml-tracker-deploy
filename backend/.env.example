# Groq API key for the chatbot module (console.groq.com)
GROQ_API_KEY=

# Optional: override the Groq model (default: llama3-8b-8192)
GROQ_MODEL=llama3-8b-8192

# Optional: GitHub personal access token — bumps rate limit from 60/h to 5000/h
# Only needs `public_repo` scope (read-only). Leave blank for unauthenticated calls.
GITHUB_TOKEN=

# SMTP — used for OTP emails on registration
# Gmail: enable 2FA → Google Account → Security → App Passwords → generate 16-char password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=your@gmail.com
