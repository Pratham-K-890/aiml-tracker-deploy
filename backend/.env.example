# Copy this file to .env and fill in the values before running the server.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Settings → API → Project URL  (include the trailing /rest/v1/)
SUPABASE_URL=https://<your-project-ref>.supabase.co/rest/v1/

# Settings → API → service_role secret  (never expose to browser clients)
SUPABASE_SERVICE_KEY=<service-role-key>

# Settings → API → JWT Secret
SUPABASE_JWT_SECRET=<jwt-secret>

# ── AI (Groq) ─────────────────────────────────────────────────────────────────
# console.groq.com → API Keys
GROQ_API_KEY=<groq-api-key>

# Optional: override the model (default: llama-3.1-8b-instant)
GROQ_MODEL=llama-3.1-8b-instant

# ── GitHub ────────────────────────────────────────────────────────────────────
# Optional: personal access token with public_repo scope.
# Raises the API rate limit from 60 to 5000 requests/hour.
GITHUB_TOKEN=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave as * for local dev or when nginx guarantees same-origin.
# Production example: ALLOWED_ORIGINS=http://192.168.1.100
ALLOWED_ORIGINS=*
